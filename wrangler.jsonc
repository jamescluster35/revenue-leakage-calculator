{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "revenue-leakage-calculator",
  "compatibility_date": "2026-06-22",
  "main": "src/index.js",
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "bdl.dataconnectmail.com",
      "zone_name": "dataconnectmail.com",
      "custom_domain": true
    }
  ]
}
